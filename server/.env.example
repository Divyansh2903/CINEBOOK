# Copy to .env and adjust as needed
NODE_ENV=development
PORT=4000

# Postgres (matches docker-compose.yml). POSTGRES_PASSWORD is consumed by both
# the postgres service and the DATABASE_URL override in docker-compose.yml.
POSTGRES_PASSWORD="change-me"
DATABASE_URL="postgresql://app:change-me@postgres:5432/cinebook?schema=public"

# Auth
JWT_SECRET="dev-change-me-please-32-bytes-minimum"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# Optional fixed OTP accepted for ANY phone (demo/review only). Must be 6 chars.
# Leave empty to disable. Example: DEMO_OTP="001122"
DEMO_OTP=""

# Claude (chatbot) — get a key from console.anthropic.com
ANTHROPIC_API_KEY=""
CHAT_MODEL="claude-sonnet-4-6"

# CORS (admin dashboard origin)
CORS_ORIGIN="http://localhost:5173"

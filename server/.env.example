# Copy to .env and adjust as needed
NODE_ENV=development
PORT=4000

# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://cinebook:cinebook@localhost:5432/cinebook?schema=public"

# Auth
JWT_SECRET="dev-change-me-please-32-bytes-minimum"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# Claude (chatbot) — get a key from console.anthropic.com
ANTHROPIC_API_KEY=""
CHAT_MODEL="claude-sonnet-4-6"

# CORS (admin dashboard origin)
CORS_ORIGIN="http://localhost:5173"
